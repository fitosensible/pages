<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>El rizobio — Fitosensible</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-a:#dfe7d4; --bg-b:#cdddc6;
    --leaf-d:#5c8b3e; --flower:#ecc24b; --ink:#37452f; --ink-soft:#5c6b52;
    --card:#fbf6e9; --card-line:#e6ddc6; --shadow:rgba(60,74,45,.22);
    --n2:#6FA8C7; --nh3:#7ec96b; --o2:#d0503f; --azucar:#e0a33c; --legh:#e88897;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{font-family:"Nunito",system-ui,sans-serif;color:var(--ink);
    background:radial-gradient(120% 90% at 50% 6%, var(--bg-a) 0%, var(--bg-b) 70%, #bfd0b8 100%);
    min-height:100dvh;display:flex;align-items:center;justify-content:center;
    padding:clamp(10px,3vw,22px);-webkit-font-smoothing:antialiased}
  .game{width:min(390px,100%);display:flex;flex-direction:column;gap:clamp(8px,1.8vw,12px)}
  .eyebrow{font-weight:800;font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;
    color:var(--leaf-d);display:flex;align-items:center;gap:.5em;margin:0}
  .eyebrow .dot{width:.5em;height:.5em;border-radius:50%;background:var(--flower);box-shadow:0 0 0 3px rgba(236,194,75,.28)}
  h1{font-family:"Fredoka";font-weight:600;font-size:clamp(1.35rem,5vw,1.7rem);line-height:1.05;margin:.12em 0 0}
  .sub{margin:.28em 0 0;color:var(--ink-soft);font-size:clamp(.86rem,2.5vw,.94rem);max-width:42ch}

  .bars{display:flex;gap:8px}
  .b{flex:1}
  .b .lb{font-size:.64rem;font-weight:800;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:3px}
  .b .tr{height:8px;background:rgba(255,255,255,.65);border-radius:999px;overflow:hidden;box-shadow:inset 0 1px 2px rgba(60,74,45,.12)}
  .b .tr i{display:block;height:100%;border-radius:999px;transition:width .18s linear}
  .b.atp i{background:linear-gradient(90deg,var(--azucar),#f0bf62)}
  .b.enz i{background:linear-gradient(90deg,var(--legh),#f2a8b4)}
  .b.pl i{background:linear-gradient(90deg,var(--leaf-d),#8fbc63)}

  .stage{position:relative;border-radius:24px;overflow:hidden;touch-action:none;aspect-ratio:1/1.22;background:#2a2016;
    box-shadow:inset 0 2px 0 rgba(255,255,255,.5),0 16px 30px -20px var(--shadow),0 5px 12px -10px var(--shadow)}
  canvas{display:block;width:100%;height:100%}

  .capa{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;align-items:center;
    text-align:center;padding:clamp(14px,4vw,20px);background:rgba(251,246,233,.96);overflow-y:auto;
    animation:rise .5s cubic-bezier(.34,1.4,.64,1) both}
  @keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
  .capa .emo{font-size:2.6rem;line-height:1;margin-bottom:.3rem;animation:pop .55s ease both}
  @keyframes pop{from{opacity:0;transform:scale(.75)}to{opacity:1;transform:scale(1)}}
  .capa h2{font-family:"Fredoka";font-weight:600;font-size:1.25rem;margin:0 0 .45em;line-height:1.15}
  .capa p{margin:0 0 .7em;font-size:.9rem;line-height:1.5;max-width:33ch}
  .capa .dato{background:rgba(110,162,78,.14);border-radius:12px;padding:.65rem .85rem;font-size:.82rem;
    line-height:1.45;max-width:33ch;margin-bottom:1rem;text-align:left}
  .hl{background:linear-gradient(180deg,transparent 62%,#fbe6a3 62%);font-weight:700;padding:0 .1em}
  .reglas{list-style:none;padding:0;margin:0 0 1rem;text-align:left;font-size:.85rem;max-width:31ch}
  .reglas li{margin-bottom:.4em;padding-left:1.7em;position:relative;line-height:1.35}
  .reglas .ic{position:absolute;left:0}
  .btn{appearance:none;cursor:pointer;font-family:"Fredoka";font-weight:600;font-size:.94rem;border-radius:13px;
    padding:.66em 1.3em;border:none;transition:transform .18s cubic-bezier(.34,1.56,.64,1),background .18s}
  .btn:active{transform:translateY(1px)}
  .btn-primary{background:var(--leaf-d);color:#fff;box-shadow:0 8px 16px -8px var(--leaf-d)}
  .btn-primary:hover{background:#517d35}
  .keyshint{font-size:.8rem;color:var(--ink-soft);text-align:center;margin:0;line-height:1.35}
  .credit{text-align:center;font-size:.75rem;color:var(--ink-soft);margin:0}
  .oculto{display:none !important}
  @media (prefers-reduced-motion:reduce){*{animation:none !important}}
</style>
</head>
<body>
<main class="game">
  <header>
    <p class="eyebrow"><span class="dot"></span>Fitosensible · juego</p>
    <h1>El rizobio</h1>
    <p class="sub">Vives dentro de la raíz de un frijol. La planta te da casa y comida, pero espera algo a cambio: nitrógeno del aire, que solo tú sabes romper. Haz el trato… o muere en el intento.</p>
  </header>

  <div class="bars">
    <div class="b atp"><div class="lb">⚡ Energía</div><div class="tr"><i id="b-atp" style="width:100%"></i></div></div>
    <div class="b enz"><div class="lb">🧬 Enzima</div><div class="tr"><i id="b-enz" style="width:100%"></i></div></div>
    <div class="b pl"><div class="lb">🌱 La planta</div><div class="tr"><i id="b-pl" style="width:0%"></i></div></div>
  </div>

  <section class="stage" id="stage">
    <canvas id="cv"></canvas>
    <div class="capa" id="c-inicio">
      <div class="emo">🦠</div>
      <h2>Eres un rizobio</h2>
      <p>Estás dentro de un nódulo. Tu enzima —la <strong>nitrogenasa</strong>— rompe el nitrógeno del aire… pero <span class="hl">el oxígeno la envenena</span>.</p>
      <ul class="reglas">
        <li><span class="ic">🔵</span> Atrapa <strong>N₂</strong> (cuesta poquito)</li>
        <li><span class="ic">🌸</span> Llévalo a una <strong>zona rosa</strong>: ahí no hay oxígeno, y solo ahí puedes convertirlo (cuesta caro)</li>
        <li><span class="ic">🟢</span> Ya convertido, <strong>súbelo a la raíz</strong></li>
        <li><span class="ic">🟡</span> Ella te paga con <strong>azúcares</strong> y te abre más zonas rosas</li>
        <li><span class="ic">🔴</span> Fuera de las zonas rosas, el <strong>oxígeno</strong> te mata</li>
      </ul>
      <button class="btn btn-primary" onclick="empezar()">Entrar al nódulo</button>
    </div>
    <div class="capa oculto" id="c-fin">
      <div class="emo" id="f-emo"></div>
      <h2 id="f-tit"></h2>
      <p id="f-txt"></p>
      <div class="dato" id="f-dato"></div>
      <button class="btn btn-primary" onclick="empezar()">Otra vez</button>
    </div>
  </section>

  <p class="keyshint">Toca a dónde ir · o usa las flechas / WASD</p>
  <p class="credit">Un juego de <strong>Fitosensible</strong></p>
</main>

<script>
const BACT=new Image();
BACT.src="data:image/png;base64,";
const CX=0.72;  // centro del cuerpo dentro del sprite

const cv=document.getElementById('cv'),ctx=cv.getContext('2d'),stage=document.getElementById('stage');
let W,H,DPR;
function fit(){DPR=Math.min(window.devicePixelRatio||1,2);
  const r=stage.getBoundingClientRect();W=r.width;H=r.height;
  cv.width=W*DPR;cv.height=H*DPR;ctx.setTransform(DPR,0,0,DPR,0,0);}
addEventListener('resize',fit);

let G=null,raf=null,keys={},meta=null,arr=false;
const OFF=46;
function apunta(e){const r=cv.getBoundingClientRect();meta={x:e.clientX-r.left,y:(e.clientY-r.top)-OFF};}
cv.addEventListener('pointerdown',e=>{e.preventDefault();apunta(e);arr=true;cv.setPointerCapture(e.pointerId);});
cv.addEventListener('pointermove',e=>{if(arr)apunta(e);});
cv.addEventListener('pointerup',()=>arr=false);
cv.addEventListener('pointercancel',()=>arr=false);
addEventListener('keydown',e=>{keys[e.key.toLowerCase()]=1;
  if(['arrowup','arrowdown','arrowleft','arrowright',' '].includes(e.key.toLowerCase()))e.preventDefault();});
addEventListener('keyup',e=>keys[e.key.toLowerCase()]=0);

function empezar(){
  fit();meta=null;
  document.getElementById('c-inicio').classList.add('oculto');
  document.getElementById('c-fin').classList.add('oculto');
  G={x:W/2,y:H*.7,dx:1,dy:0,r:15,atp:100,enz:100,planta:0,
     lleva:0,      // 0=nada, 1=N2 crudo, 2=NH3 convertido
     n2:[],o2:[],suc:[],part:[],ref:[],t:0,tO2:0,fin:null,msg:'',msgT:0,conv:0};
  for(let i=0;i<5;i++)nuevoN2();
  for(let i=0;i<2;i++)nuevoO2();
  // SIEMPRE hay refugios desde el inicio (ahí ocurre la fijación)
  nuevoRef(); nuevoRef();
  if(raf)cancelAnimationFrame(raf);
  bucle();
}
function nuevoN2(){G.n2.push({x:28+Math.random()*(W-56),y:H*.3+Math.random()*(H*.56),ph:Math.random()*6});}
function nuevoO2(){G.o2.push({x:Math.random()<.5?-20:W+20,y:H*.32+Math.random()*(H*.56),sp:.5+Math.random()*.3,ph:Math.random()*6});}
function nuevoRef(){
  G.ref.push({x:55+Math.random()*(W-110), y:H*.36+Math.random()*(H*.5),
              r:48+Math.random()*12, ph:Math.random()*6,
              vida:1, edad:0, dur:520+Math.random()*380});
}
function chispas(x,y,c,n=8){for(let i=0;i<n;i++){const a=Math.random()*6.28,s=1+Math.random()*2.4;
  G.part.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,vida:1,col:c});}}
function decir(t){G.msg=t;G.msgT=110;}

function bucle(){
  if(!G||G.fin)return;
  G.t++;
  const RAIZ=H*.17, VEL=3.3;

  let tx=null,ty=null;
  if(meta){tx=meta.x;ty=meta.y;}
  let kx=0,ky=0;
  if(keys['arrowleft']||keys['a'])kx-=1;
  if(keys['arrowright']||keys['d'])kx+=1;
  if(keys['arrowup']||keys['w'])ky-=1;
  if(keys['arrowdown']||keys['s'])ky+=1;
  if(kx||ky){const m=Math.hypot(kx,ky);tx=G.x+(kx/m)*100;ty=G.y+(ky/m)*100;meta=null;}
  if(tx!==null){
    const dx=tx-G.x,dy=ty-G.y,d=Math.hypot(dx,dy);
    if(d>3){const p=Math.min(VEL,d);G.x+=(dx/d)*p;G.y+=(dy/d)*p;G.dx=dx/d;G.dy=dy/d;}
    else if(meta&&!arr)meta=null;
  }
  G.x=Math.max(G.r,Math.min(W-G.r,G.x));
  G.y=Math.max(RAIZ+10,Math.min(H-G.r,G.y));
  G.atp-=.022;

  // ── REFUGIOS: nacen, viven, mueren. Más si la planta te quiere.
  const maxRef = 2 + Math.floor(G.planta/25);
  G.ref.forEach((r,i)=>{
    r.ph+=.03; r.edad++;
    if(r.edad<45) r.vida=r.edad/45;                     // aparece
    else if(r.edad>r.dur-55) r.vida=Math.max(0,(r.dur-r.edad)/55);  // se desvanece
    else r.vida=1;
    if(r.edad>r.dur) G.ref.splice(i,1);
  });
  if(G.ref.length<maxRef && G.t%80===0) nuevoRef();
  if(G.ref.length===0) nuevoRef();                      // nunca te quedes sin ninguno

  let dentro=null;
  G.ref.forEach(r=>{ if(r.vida>.4 && Math.hypot(r.x-G.x,r.y-G.y)<r.r*.95) dentro=r; });
  const seguro = !!dentro;

  // ── 1. ATRAPAR N2 (barato)
  if(G.lleva===0){
    G.n2.forEach((n,i)=>{
      n.ph+=.05;
      if(Math.hypot(n.x-G.x,n.y-G.y)<G.r+11){
        if(G.atp>8){ G.atp-=4; G.lleva=1; chispas(n.x,n.y,'#6FA8C7',10);
          G.n2.splice(i,1); nuevoN2();
          decir('Llévalo a una zona rosa 🌸'); }
        else decir('Sin energía ni para agarrarlo');
      }
    });
  } else { G.n2.forEach(n=>n.ph+=.05); }

  // ── 2. CONVERTIR (caro, SOLO dentro del refugio)
  if(G.lleva===1 && dentro){
    G.conv++;
    if(G.conv%3===0) G.atp-=0.45;                 // gasto sostenido: la nitrogenasa trabajando
    chispas(G.x+(Math.random()-.5)*20, G.y+(Math.random()-.5)*20, '#7ec96b', 1);
    if(G.conv>=70){                              // ~1.6 s de trabajo
      G.lleva=2; G.conv=0;
      chispas(G.x,G.y,'#7ec96b',22);
      decir('¡Convertido! Súbelo a la raíz ↑');
    }
  } else if(G.lleva===1 && !dentro && G.conv>0){
    G.conv=Math.max(0,G.conv-2);                 // saliste: se pierde el avance
  }

  // ── 3. ENTREGAR en la raíz (solo si ya está convertido)
  if(G.y<RAIZ+32){
    if(G.lleva===2){
      G.planta=Math.min(100,G.planta+11);
      G.atp=Math.min(100,G.atp+42);
      G.lleva=0;
      chispas(G.x,RAIZ+16,'#e0a33c',22);
      for(let k=0;k<7;k++)G.suc.push({x:G.x+(Math.random()-.5)*46,y:RAIZ+18,vy:.8+Math.random(),ph:Math.random()*6});
      decir('Te pagó azúcares 🟡');
      if(Math.random()<.7) nuevoRef();
    } else if(G.lleva===1){
      decir('Está crudo: conviértelo en la zona rosa');
    }
  }
  G.suc.forEach((s,i)=>{s.y+=s.vy;s.ph+=.1;if(s.y>H)G.suc.splice(i,1);});

  // ── O2
  G.o2.forEach(o=>{
    o.ph+=.07;
    let ox=G.x,oy=G.y;
    G.ref.forEach(r=>{const d=Math.hypot(r.x-o.x,r.y-o.y);
      if(r.vida>.4 && d<r.r+38){ox+=(o.x-r.x)*2.8;oy+=(o.y-r.y)*2.8;}});
    const dx=ox-o.x,dy=oy-o.y,d=Math.hypot(dx,dy)||1;
    o.x+=(dx/d)*o.sp;o.y+=(dy/d)*o.sp;
    if(Math.hypot(o.x-G.x,o.y-G.y)<G.r+13 && !seguro){G.enz-=.42;chispas(G.x,G.y,'#d0503f',2);}
  });
  G.tO2++;
  if(G.tO2>520 && G.o2.length<6){nuevoO2();G.tO2=0;}

  G.part.forEach((p,i)=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.05;p.vida-=.03;if(p.vida<=0)G.part.splice(i,1);});

  G.atp=Math.max(0,Math.min(100,G.atp));G.enz=Math.max(0,Math.min(100,G.enz));
  document.getElementById('b-atp').style.width=G.atp+'%';
  document.getElementById('b-enz').style.width=G.enz+'%';
  document.getElementById('b-pl').style.width=G.planta+'%';

  if(G.planta>=100)return final('gano');
  if(G.atp<=0)return final('hambre');
  if(G.enz<=0)return final('oxigeno');

  dibujar(RAIZ,seguro,dentro);
  if(G.msgT>0)G.msgT--;
  raf=requestAnimationFrame(bucle);
}

function dibujar(RAIZ,seguro,dentro){
  const g=ctx.createRadialGradient(W/2,H*.62,20,W/2,H*.62,H*.8);
  g.addColorStop(0,'#4a3120');g.addColorStop(1,'#241a11');
  ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
  ctx.strokeStyle='rgba(201,179,140,.055)';ctx.lineWidth=1;
  for(let y=RAIZ+40;y<H;y+=46)for(let x=0;x<W+46;x+=46){
    ctx.beginPath();ctx.arc(x+((y/46)%2)*23,y,22,0,6.29);ctx.stroke();}

  // ── LA PARED DE LA RAÍZ (tejido vegetal, con haces vasculares)
  const rg=ctx.createLinearGradient(0,0,0,RAIZ);
  rg.addColorStop(0,'#b8925f'); rg.addColorStop(1,'#8f6f45');
  ctx.fillStyle=rg; ctx.fillRect(0,0,W,RAIZ);
  // células del tejido
  ctx.strokeStyle='rgba(90,66,38,.35)'; ctx.lineWidth=1.2;
  for(let y=8;y<RAIZ;y+=15) for(let x=-8;x<W+16;x+=22){
    ctx.beginPath(); ctx.roundRect(x+((y/15)%2)*11, y-6, 20, 13, 5); ctx.stroke();
  }
  // haces vasculares (por donde bajan los azúcares)
  for(let i=0;i<4;i++){
    const vx=(i+.5)*W/4 + Math.sin(G.t*.01+i)*4;
    ctx.strokeStyle='rgba(224,163,60,.35)'; ctx.lineWidth=4;
    ctx.beginPath(); ctx.moveTo(vx,2); ctx.lineTo(vx,RAIZ-3); ctx.stroke();
  }
  // borde orgánico ondulado
  ctx.fillStyle='#a07e52';
  ctx.beginPath(); ctx.moveTo(0,RAIZ-7);
  for(let x=0;x<=W;x+=12){ ctx.quadraticCurveTo(x+6, RAIZ+5+Math.sin(x*.25+G.t*.02)*2, x+12, RAIZ-2); }
  ctx.lineTo(W,0); ctx.lineTo(0,0); ctx.closePath(); ctx.fill();
  // pelos radiculares colgando
  ctx.strokeStyle='rgba(160,126,82,.5)'; ctx.lineWidth=2;
  for(let x=8;x<W;x+=26){
    const l=6+Math.sin(x*.5)*3;
    ctx.beginPath(); ctx.moveTo(x,RAIZ-1);
    ctx.quadraticCurveTo(x+Math.sin(G.t*.03+x)*3, RAIZ+l*.6, x+Math.sin(G.t*.03+x)*4, RAIZ+l);
    ctx.stroke();
  }
  ctx.fillStyle='rgba(251,246,233,.85)';ctx.font='700 11px Fredoka, system-ui';ctx.textAlign='center';
  ctx.fillText('▲ LA RAÍZ — entrega aquí',W/2,RAIZ-11);

  // ── REFUGIOS (leghemoglobina): donde SÍ se puede fijar
  G.ref.forEach(r=>{
    const p=1+Math.sin(r.ph)*.045, R=r.r*p, al=r.vida;
    const rr=ctx.createRadialGradient(r.x,r.y,4,r.x,r.y,R);
    rr.addColorStop(0,`rgba(232,136,151,${.40*al})`);
    rr.addColorStop(.65,`rgba(232,136,151,${.17*al})`);
    rr.addColorStop(1,'rgba(232,136,151,0)');
    ctx.fillStyle=rr;ctx.beginPath();ctx.arc(r.x,r.y,R,0,6.29);ctx.fill();
    ctx.strokeStyle=`rgba(242,168,180,${.5*al})`;ctx.lineWidth=1.5;ctx.setLineDash([5,6]);
    ctx.beginPath();ctx.arc(r.x,r.y,R*.95,0,6.29);ctx.stroke();ctx.setLineDash([]);
  });

  G.suc.forEach(s=>{ctx.fillStyle='rgba(224,163,60,'+Math.max(0,1-s.y/H)+')';
    ctx.beginPath();ctx.arc(s.x,s.y,3.6+Math.sin(s.ph),0,6.29);ctx.fill();});

  // N2 sueltos
  G.n2.forEach(n=>{
    ctx.fillStyle='#6FA8C7';
    ctx.beginPath();ctx.arc(n.x-4.5,n.y,5.5,0,6.29);ctx.fill();
    ctx.beginPath();ctx.arc(n.x+4.5,n.y,5.5,0,6.29);ctx.fill();
    ctx.strokeStyle='rgba(111,168,199,.7)';ctx.lineWidth=2.4;
    ctx.beginPath();ctx.moveTo(n.x-4,n.y);ctx.lineTo(n.x+4,n.y);ctx.stroke();
  });

  // O2
  G.o2.forEach(o=>{
    const p=Math.sin(o.ph)*1.3;
    const og=ctx.createRadialGradient(o.x,o.y,1,o.x,o.y,14+p);
    og.addColorStop(0,'#e8705e');og.addColorStop(1,'rgba(208,80,63,.1)');
    ctx.fillStyle=og;ctx.beginPath();ctx.arc(o.x,o.y,14+p,0,6.29);ctx.fill();
    ctx.fillStyle='#d0503f';
    ctx.beginPath();ctx.arc(o.x-3.8,o.y,4.6,0,6.29);ctx.fill();
    ctx.beginPath();ctx.arc(o.x+3.8,o.y,4.6,0,6.29);ctx.fill();
  });

  G.part.forEach(p=>{ctx.globalAlpha=Math.max(0,p.vida);ctx.fillStyle=p.col;
    ctx.beginPath();ctx.arc(p.x,p.y,2.6,0,6.29);ctx.fill();ctx.globalAlpha=1;});

  // destino
  if(meta){
    const mx=meta.x,my=meta.y,pu=(G.t*.09)%1;
    for(let k=0;k<2;k++){const p=(pu+k*.5)%1;
      ctx.strokeStyle=`rgba(140,200,95,${.55*(1-p)})`;ctx.lineWidth=2.5;
      ctx.beginPath();ctx.arc(mx,my,8+p*20,0,6.29);ctx.stroke();}
    ctx.fillStyle='rgba(140,200,95,.95)';ctx.beginPath();ctx.arc(mx,my,4.5,0,6.29);ctx.fill();
    ctx.strokeStyle='rgba(251,246,233,.8)';ctx.lineWidth=1.5;
    ctx.beginPath();ctx.arc(mx,my,4.5,0,6.29);ctx.stroke();
    const dx=mx-G.x,dy=my-G.y,d=Math.hypot(dx,dy);
    if(d>38){
      const a=Math.atan2(dy,dx);
      const x0=G.x+Math.cos(a)*(G.r+12),y0=G.y+Math.sin(a)*(G.r+12);
      const x1=mx-Math.cos(a)*17,y1=my-Math.sin(a)*17;
      const gr2=ctx.createLinearGradient(x0,y0,x1,y1);
      gr2.addColorStop(0,'rgba(140,200,95,.2)');gr2.addColorStop(1,'rgba(140,200,95,.9)');
      ctx.strokeStyle=gr2;ctx.lineWidth=4;ctx.lineCap='round';
      ctx.beginPath();ctx.moveTo(x0,y0);ctx.lineTo(x1,y1);ctx.stroke();
      ctx.fillStyle='rgba(140,200,95,.95)';
      ctx.beginPath();
      ctx.moveTo(x1+Math.cos(a)*12,y1+Math.sin(a)*12);
      ctx.lineTo(x1+Math.cos(a+2.5)*9,y1+Math.sin(a+2.5)*9);
      ctx.lineTo(x1+Math.cos(a-2.5)*9,y1+Math.sin(a-2.5)*9);
      ctx.closePath();ctx.fill();
    }
  }

  // ── LA BACTERIA (sprite de plastilina)
  const ang=Math.atan2(G.dy,G.dx);
  ctx.save();
  ctx.translate(G.x,G.y);
  ctx.rotate(ang);
  if(seguro){
    ctx.strokeStyle='rgba(242,168,180,.9)';ctx.lineWidth=2.5;
    ctx.beginPath();ctx.arc(0,0,G.r+9,0,6.29);ctx.stroke();
  }
  if(BACT.complete && BACT.naturalWidth){
    const bw=66, bh=bw*(BACT.naturalHeight/BACT.naturalWidth);
    const wob=Math.sin(G.t*.16)*1.2;
    ctx.drawImage(BACT, -bw*CX, -bh/2 + wob*.3, bw, bh);
  } else {
    ctx.fillStyle='#f5e9d0';ctx.beginPath();ctx.ellipse(0,0,G.r,G.r*.7,0,0,6.29);ctx.fill();
  }
  ctx.restore();

  // lo que lleva encima
  if(G.lleva===1){
    ctx.fillStyle='#6FA8C7';
    ctx.beginPath();ctx.arc(G.x-4,G.y-G.r-11,4.4,0,6.29);ctx.fill();
    ctx.beginPath();ctx.arc(G.x+4,G.y-G.r-11,4.4,0,6.29);ctx.fill();
    ctx.strokeStyle='rgba(111,168,199,.8)';ctx.lineWidth=2;
    ctx.beginPath();ctx.moveTo(G.x-4,G.y-G.r-11);ctx.lineTo(G.x+4,G.y-G.r-11);ctx.stroke();
  } else if(G.lleva===2){
    const pu=1+Math.sin(G.t*.2)*.12;
    ctx.fillStyle='#7ec96b';
    ctx.beginPath();ctx.arc(G.x,G.y-G.r-12,6*pu,0,6.29);ctx.fill();
    ctx.strokeStyle='rgba(180,240,160,.9)';ctx.lineWidth=2;
    ctx.beginPath();ctx.arc(G.x,G.y-G.r-12,9*pu,0,6.29);ctx.stroke();
  }

  // barra de conversión
  if(G.conv>0){
    const p=G.conv/70, bw=44;
    ctx.fillStyle='rgba(0,0,0,.45)';
    ctx.beginPath();ctx.roundRect(G.x-bw/2,G.y+G.r+8,bw,6,3);ctx.fill();
    ctx.fillStyle='#7ec96b';
    ctx.beginPath();ctx.roundRect(G.x-bw/2,G.y+G.r+8,bw*p,6,3);ctx.fill();
  }

  if(G.msgT>0){ctx.globalAlpha=Math.min(1,G.msgT/28);
    ctx.fillStyle='rgba(251,246,233,.95)';ctx.font='700 13px Fredoka, system-ui';ctx.textAlign='center';
    ctx.fillText(G.msg,W/2,H-16);ctx.globalAlpha=1;}
}

function final(t){
  G.fin=t;if(raf)cancelAnimationFrame(raf);
  const F={
    gano:['🌱','La planta creció',
      'Le entregaste nitrógeno ya convertido, ella te pagó con azúcares y te abrió más zonas sin oxígeno para que pudieras trabajar. Ni gorrón ni mártir: <span class="hl">socio</span>.',
      'Este trato lleva millones de años funcionando, ahorita mismo, bajo tus pies. Cada frijol que te comes trae nitrógeno que una bacteria le arrancó al aire.'],
    hambre:['💀','Te quedaste sin energía',
      'Convertir nitrógeno es carísimo, y tú gastaste sin entregar lo suficiente. <span class="hl">Sin entregas no hay azúcares. Sin azúcares no hay bacteria.</span>',
      'Romper el triple enlace del N₂ cuesta unos 16 ATP por molécula: una de las reacciones más caras de la biología. Por eso ninguna bacteria lo hace de gratis.'],
    oxigeno:['☠️','El oxígeno te mató',
      'Tu nitrogenasa se envenena con el aire. Te quedaste fuera de las zonas protegidas —o la planta dejó de abrírtelas porque no le dabas nada—. <span class="hl">El que no da, no recibe.</span>',
      'La leghemoglobina crea el ambiente sin oxígeno del nódulo: es lo único que permite que la nitrogenasa funcione. Es prima de la hemoglobina de tu sangre, pero en vez de repartir oxígeno, se lo traga.']
  }[t];
  document.getElementById('f-emo').textContent=F[0];
  document.getElementById('f-tit').textContent=F[1];
  document.getElementById('f-txt').innerHTML=F[2];
  document.getElementById('f-dato').textContent=F[3];
  document.getElementById('c-fin').classList.remove('oculto');
}
fit();
</script>
<script>
  function reportHeight(){
    var h = document.querySelector('.game').offsetHeight + 20;
    parent.postMessage({ type: 'rizobio-height', height: h }, '*');
  }
  if (window.ResizeObserver){
    new ResizeObserver(reportHeight).observe(document.querySelector('.game'));
  } else {
    setInterval(reportHeight, 400);
  }
  window.addEventListener('load', reportHeight);
</script>
</body>
</html>