---
import { getCollection } from 'astro:content';

import { render } from 'astro:content';

import SigueLeyendo from '../../components/SigueLeyendo.astro';

import CanalWhatsApp from '../../components/CanalWhatsApp.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { titulo, fecha, autor, imagen, descripcion } = post.data;
const { Content } = await render(post);
const fechaLegible = new Date(fecha).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });

// URL completa del artículo, para los botones de compartir
const urlArticulo = new URL(Astro.url.pathname, 'https://fitosensible.com').href;
const textoCompartir = encodeURIComponent(titulo + ' — Fitosensible');
const urlCodificada = encodeURIComponent(urlArticulo);

// Imagen social (absoluta) y descripción con respaldo por si algún post no las trae
const imagenSocial = imagen ? new URL(imagen, 'https://fitosensible.com').href : undefined;
const descripcionSocial = descripcion || titulo;
---
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{titulo} — Fitosensible</title>

		<meta name="description" content={descripcionSocial} />
		<link rel="canonical" href={urlArticulo} />

		<meta property="og:type" content="article" />
		<meta property="og:title" content={titulo + ' — Fitosensible'} />
		<meta property="og:description" content={descripcionSocial} />
		{imagenSocial && <meta property="og:image" content={imagenSocial} />}
		<meta property="og:url" content={urlArticulo} />
		<meta property="og:site_name" content="Fitosensible" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={titulo + ' — Fitosensible'} />
		<meta name="twitter:description" content={descripcionSocial} />
		{imagenSocial && <meta name="twitter:image" content={imagenSocial} />}

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body>
		<header class="masthead">
			<a class="wordmark" href="/">
				<svg class="leaf" viewBox="0 0 120 120" aria-hidden="true">
					<circle cx="60" cy="60" r="58" fill="#163A2E" />
					<path d="M60,14 C33,42 33,78 60,106 C87,78 87,42 60,14 Z" fill="#EFE7D3" />
					<path d="M60,24 L60,54" stroke="#163A2E" stroke-width="5" stroke-linecap="round" fill="none" />
					<path d="M60,66 Q67,74 60,82 Q53,90 60,100" stroke="#163A2E" stroke-width="5" stroke-linecap="round" fill="none" />
					<circle cx="60" cy="60" r="5.5" fill="#D4A24C" />
				</svg>
				<span>Fitosensible</span>
			</a>
			<nav class="nav">
				<a href="/">Inicio</a>
			</nav>
		</header>

		<main class="articulo">
			<p class="eyebrow">Divulgación científica</p>
			<h1>{titulo}</h1>
			<div class="meta">
			<img class="autor-foto" src="/PedroJS_cuadrada.jpg" alt="Pedro Jiménez-Sandoval" />
			<span>Por {autor} · {fechaLegible}</span>
			</div>
			<div class="cuerpo">
				<Content />
			</div>

			<!-- COMPARTIR -->
            <div class="compartir">
                <p class="compartir-titulo">¿Te gustó? Compártelo</p>
                <div class="compartir-botones">
                    <a href={`https://wa.me/?text=${textoCompartir}%20${urlCodificada}`} target="_blank" rel="noopener">WhatsApp</a>
                    <a href={`https://x.com/intent/tweet?text=${textoCompartir}&url=${urlCodificada}`} target="_blank" rel="noopener">X</a>
                    <a href={`https://www.facebook.com/sharer/sharer.php?u=${urlCodificada}`} target="_blank" rel="noopener">Facebook</a>
                    <button id="copiar" data-url={urlArticulo}>Copiar enlace</button>
                </div>
            </div>

            <SigueLeyendo actual={post.id} />
			<CanalWhatsApp />
		</main>

		<footer class="footer">
		<a class="volver" href="/">← Volver a Fitosensible</a>
		</footer>
		<script>
			const boton = document.getElementById('copiar');
			if (boton) {
				boton.addEventListener('click', async () => {
					const url = boton.getAttribute('data-url');
					try {
						await navigator.clipboard.writeText(url);
						const original = boton.textContent;
						boton.textContent = '¡Copiado!';
						setTimeout(() => { boton.textContent = original; }, 2000);
					} catch (e) {
						boton.textContent = 'Copia manual: ' + url;
					}
				});
			}
		</script>

		<!-- MOTOR DEL QUIZ (una pregunta a la vez, barra de progreso, marcador y reintentar) -->
		<script>
			(function () {
				function initQuiz(quiz) {
					var questions = Array.prototype.slice.call(quiz.querySelectorAll('.quiz-q'));
					var total = questions.length;
					if (!total) return;
					var current = 0;
					var score = 0;

					var bar = document.createElement('div');
					bar.className = 'quiz-bar';
					var fill = document.createElement('div');
					fill.className = 'quiz-bar-fill';
					bar.appendChild(fill);
					var title = quiz.querySelector('.quiz-title');
					title.parentNode.insertBefore(bar, title.nextSibling);

					var counter = document.createElement('p');
					counter.className = 'quiz-counter';
					bar.parentNode.insertBefore(counter, bar.nextSibling);

					var nav = document.createElement('div');
					nav.className = 'quiz-nav';
					var fb = document.createElement('p');
					fb.className = 'quiz-fb';
					var next = document.createElement('button');
					next.className = 'quiz-next';
					next.type = 'button';
					next.textContent = 'Siguiente →';
					next.style.display = 'none';
					nav.appendChild(fb);
					nav.appendChild(next);

					var result = document.createElement('div');
					result.className = 'quiz-result';
					result.style.display = 'none';

					quiz.appendChild(nav);
					quiz.appendChild(result);

					function show(i) {
						questions.forEach(function (q, idx) { q.style.display = idx === i ? 'block' : 'none'; });
						counter.textContent = 'Pregunta ' + (i + 1) + ' de ' + total;
						fill.style.width = (i / total) * 100 + '%';
						fb.textContent = '';
						next.style.display = 'none';
					}

					function finish() {
						questions.forEach(function (q) { q.style.display = 'none'; });
						nav.style.display = 'none';
						counter.style.display = 'none';
						fill.style.width = '100%';
						var msg;
						if (score === total) msg = '¡' + score + '/' + total + '! Eres oficialmente hijo del maíz. 🌽👑';
						else if (score >= Math.ceil(total * 0.6)) msg = score + '/' + total + '. Nada mal, ya traes la milpa en la sangre. 🌱';
						else msg = score + '/' + total + '. Uy, relee el artículo y vuelve por la revancha. 😉';
						result.innerHTML = '<p class="quiz-score">' + msg + '</p>';
						var retry = document.createElement('button');
						retry.className = 'quiz-retry';
						retry.type = 'button';
						retry.textContent = '↻ Reintentar';
						retry.addEventListener('click', reset);
						result.appendChild(retry);
						result.style.display = 'block';
					}

					function reset() {
						current = 0; score = 0;
						questions.forEach(function (q) {
							q.classList.remove('done');
							q.querySelectorAll('.quiz-opts button').forEach(function (b) {
								b.classList.remove('ok', 'no');
								b.disabled = false;
							});
						});
						result.style.display = 'none';
						nav.style.display = '';
						counter.style.display = '';
						show(0);
					}

					quiz.addEventListener('click', function (e) {
						var btn = e.target.closest('.quiz-opts button');
						if (!btn) return;
						var q = btn.closest('.quiz-q');
						if (q.classList.contains('done')) return;
						q.classList.add('done');
						var correct = btn.hasAttribute('data-ok');
						if (correct) score++;
						q.querySelectorAll('.quiz-opts button').forEach(function (b) {
							if (b.hasAttribute('data-ok')) b.classList.add('ok');
							b.disabled = true;
						});
						btn.classList.add(correct ? 'ok' : 'no');
						fb.textContent = btn.getAttribute('data-fb') || '';
						next.textContent = (current === total - 1) ? 'Ver resultado →' : 'Siguiente →';
						next.style.display = 'inline-block';
					});

					next.addEventListener('click', function () {
						current++;
						if (current >= total) finish();
						else show(current);
					});

					show(0);
				}

				document.querySelectorAll('[data-quiz]').forEach(initQuiz);
			})();
		</script>

		<style is:global>
			:root {
				--papel: #F4EFE3;
				--verde: #163A2E;
				--tinta: #1B2A22;
				--dorado: #C08A2D;
			}
			* { box-sizing: border-box; padding: 0; }
			body {
				background: var(--papel);
				color: var(--tinta);
				font-family: 'Work Sans', sans-serif;
				line-height: 1.7;
				-webkit-font-smoothing: antialiased;
			}
			.masthead {
				max-width: 720px; margin: 0 auto; padding: 1.6rem 2rem;
				display: flex; align-items: center; justify-content: space-between;
				border-bottom: 1px solid rgba(27,42,34,0.15);
			}
			.wordmark { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; color: var(--verde); }
			.wordmark .leaf { width: 32px; height: 32px; }
			.wordmark span { font-family: 'Newsreader', serif; font-size: 1.4rem; font-weight: 600; }
			.nav a { color: var(--tinta); text-decoration: none; font-size: 0.95rem; }
			.nav a:hover { color: var(--dorado); }

			.articulo { max-width: 680px; margin: 0 auto; padding: 3.5rem 2rem 2rem; }
			.eyebrow {
				font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
				color: var(--dorado); font-weight: 600; margin-bottom: 1rem;
			}
			.articulo h1 {
				font-family: 'Newsreader', serif; font-weight: 500; line-height: 1.15;
				font-size: clamp(2rem, 5vw, 3.2rem); color: var(--verde); margin-bottom: 1rem;
			}
			.meta {
			display: flex;
			align-items: center;
			gap: 0.7rem;
			color: rgba(27,42,34,0.6);
			font-size: 0.95rem;
			margin-bottom: 3rem;
			}
			.autor-foto {
			width: 64px;
			height: 64px;
			border-radius: 50%;
			object-fit: cover;
			}

			.cuerpo { font-size: 1.15rem; }
			:global(.cuerpo h2) {
				font-family: 'Newsreader', serif; font-weight: 500;
				font-size: 1.7rem; color: var(--verde);
				margin-top: 2.8rem !important; margin-bottom: 1rem !important;
			}
			:global(.cuerpo p),
			:global(.cuerpo > p),
			.cuerpo :global(p) {
			margin-bottom: 1.4rem !important;
			}
			:global(.cuerpo h2),
			.cuerpo :global(h2) {
			margin-top: 2.8rem !important;
			margin-bottom: 1rem !important;
			}
			:global(.cuerpo strong) { color: var(--verde); }
			:global(.cuerpo em) { color: rgba(27,42,34,0.75); }
			:global(.cuerpo a) { color: var(--dorado); text-decoration: underline; }
			:global(.cuerpo hr) { border: none; border-top: 1px solid rgba(27,42,34,0.15); margin: 2.5rem 0; }
			:global(.cuerpo figure) {
    			margin: 2.5rem 0;
    			text-align: center;
			}
			:global(.cuerpo img) {
    			max-width: 100%;
    			height: auto;
    			border-radius: 8px;
    			display: block;
    			margin: 0 auto;
			}
			:global(.cuerpo figcaption) {
    			font-size: 0.85rem;
    			color: rgba(27,42,34,0.6);
    			line-height: 1.5;
    			margin-top: 0.7rem;
    			font-style: italic;
			}
			/* Estilo para citas destacadas */
			.pull-quote {
    			margin: 2.5rem 0;
    			padding-left: 1.2rem;
    			border-left: 4px solid var(--dorado);
    			font-family: inherit; /* Hereda Work Sans */
    			font-size: 1rem;      /* El mismo tamaño que tus párrafos */
    			font-style: italic;
    			color: var(--tinta);  /* El mismo color que el texto normal */
    			max-width: 46ch;
			}
			/* Esto asegura que cualquier small dentro de una figura en .cuerpo tenga este estilo */
			.cuerpo figure figcaption small {
    			display: block !important;
    			font-size: 0.75rem !important;
    			color: #666 !important;
    			line-height: 1.2 !important;
    			margin-top: 0.5rem !important;
			}
			:global(.cuerpo figcaption a) {
    			color: var(--dorado);
			}
			:global(.cuerpo figure figcaption .credito) {
    			display: block !important;
    			font-size: 0.72rem !important;
    			color: rgba(27,42,34,0.5) !important;
    			margin-top: 0.3rem !important;
    			font-style: normal !important;
    			background: transparent !important;
			}

			/* QUIZ */
			:global(.cuerpo .quiz) {
				margin: 3.5rem 0 1rem;
				padding: 1.8rem 1.6rem;
				border: 1px solid rgba(27,42,34,0.18);
				border-radius: 12px;
				background: rgba(255,255,255,0.35);
			}
			:global(.cuerpo .quiz-top) {
				font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase;
				color: var(--dorado); font-weight: 600; margin-bottom: 0.3rem !important;
			}
			:global(.cuerpo .quiz-title) {
				font-family: 'Newsreader', serif; font-weight: 500; font-size: 1.5rem;
				color: var(--verde); margin: 0 0 1rem !important;
			}
			:global(.cuerpo .quiz-bar) {
				height: 6px; background: rgba(27,42,34,0.12); border-radius: 999px;
				overflow: hidden; margin-bottom: 0.5rem;
			}
			:global(.cuerpo .quiz-bar-fill) {
				height: 100%; width: 0; background: var(--dorado);
				border-radius: 999px; transition: width 0.35s ease;
			}
			:global(.cuerpo .quiz-counter) {
				font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase;
				color: rgba(27,42,34,0.55); margin-bottom: 1.3rem !important;
			}
			:global(.cuerpo .quiz-qp) {
				font-weight: 600; color: var(--verde); font-size: 1.1rem;
				margin-bottom: 0.9rem !important;
			}
			:global(.cuerpo .quiz-opts) { display: flex; flex-direction: column; gap: 0.5rem; }
			:global(.cuerpo .quiz-opts button) {
				font-family: 'Work Sans', sans-serif; font-size: 0.98rem; text-align: left;
				padding: 0.7rem 1rem; border: 1px solid rgba(27,42,34,0.2); border-radius: 10px;
				background: var(--papel); color: var(--tinta); cursor: pointer;
				transition: all 0.15s; line-height: 1.4;
			}
			:global(.cuerpo .quiz-opts button:hover:not(:disabled)) { border-color: var(--dorado); }
			:global(.cuerpo .quiz-opts button:disabled) { cursor: default; opacity: 1; }
			:global(.cuerpo .quiz-opts button.ok) {
				background: var(--verde); color: var(--papel); border-color: var(--verde);
			}
			:global(.cuerpo .quiz-opts button.no) {
				background: #b23a3a; color: #fff; border-color: #b23a3a;
			}
			:global(.cuerpo .quiz-nav) {
				margin-top: 1rem; display: flex; align-items: center;
				justify-content: space-between; gap: 1rem; flex-wrap: wrap;
			}
			:global(.cuerpo .quiz-fb) {
				font-size: 0.9rem; color: rgba(27,42,34,0.75); font-style: italic;
				margin: 0 !important; flex: 1; min-width: 55%;
			}
			:global(.cuerpo .quiz-next), :global(.cuerpo .quiz-retry) {
				font-family: 'Work Sans', sans-serif; font-size: 0.9rem; font-weight: 500;
				padding: 0.5rem 1.1rem; border: none; border-radius: 999px;
				background: var(--verde); color: var(--papel); cursor: pointer;
				transition: all 0.15s; white-space: nowrap;
			}
			:global(.cuerpo .quiz-next:hover), :global(.cuerpo .quiz-retry:hover) {
				background: var(--dorado);
			}
			:global(.cuerpo .quiz-result) { text-align: center; padding: 1rem 0 0.5rem; }
			:global(.cuerpo .quiz-score) {
				font-family: 'Newsreader', serif; font-size: 1.35rem; color: var(--verde);
				margin-bottom: 1.2rem !important; line-height: 1.3;
			}

			/* COMPARTIR */
			.compartir {
				margin-top: 3.5rem;
				padding-top: 2rem;
				border-top: 1px solid rgba(27,42,34,0.15);
			}
			.compartir-titulo {
				font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase;
				color: var(--dorado); font-weight: 600; margin-bottom: 1rem;
			}
			.compartir-botones {
				display: flex; gap: 0.8rem; flex-wrap: wrap;
			}
			.compartir-botones a, .compartir-botones button {
				font-family: 'Work Sans', sans-serif;
				font-size: 0.9rem;
				padding: 0.5rem 1rem;
				border: 1px solid rgba(27,42,34,0.2);
				border-radius: 999px;
				background: transparent;
				color: var(--verde);
				text-decoration: none;
				cursor: pointer;
				transition: all 0.15s;
			}
			.compartir-botones a:hover, .compartir-botones button:hover {
				background: var(--verde);
				color: var(--papel);
				border-color: var(--verde);
			}

			.footer {
				max-width: 680px; margin: 0 auto; padding: 2.5rem 2rem 4rem;
				border-top: 1px solid rgba(27,42,34,0.15); font-size: 0.9rem;
				display: flex; justify-content: space-between; align-items: center;
				flex-wrap: wrap; gap: 1rem;
			}
			.footer .firma { font-weight: 600; color: var(--verde); }
			.footer .volver { color: var(--dorado); text-decoration: none; }
			.footer .volver:hover { text-decoration: underline; }
		
			/* ── MÓVIL: más texto por renglón ── */
			@media (max-width: 640px) {
				.articulo {
					padding: 2rem 1.1rem 1.5rem;
				}
				.cuerpo {
					font-size: 1.02rem;
					line-height: 1.65;
				}
			}
		</style>
	</body>
</html>