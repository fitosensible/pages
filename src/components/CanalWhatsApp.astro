---
// src/components/CanalWhatsApp.astro
// Invitación al canal. Va al final del artículo, después de "Sigue leyendo".

import { CANAL_WHATSAPP } from '../consts';
---

<aside class="canal">
	<div class="canal-txt">
		<p class="canal-titulo">¿Te aviso cuando salga el siguiente?</p>
		<p class="canal-bajada">
			Un mensaje cuando hay artículo nuevo. Ni uno más.
		</p>
	</div>

	<a class="canal-btn" href={CANAL_WHATSAPP} target="_blank" rel="noopener">
		<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
			<path fill="currentColor" d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.19 8.19 0 0 1 2.41 5.83c0 4.54-3.7 8.23-8.24 8.23Zm4.52-6.17c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.24-.64.8-.78.97-.15.16-.29.18-.54.06-.25-.13-1.05-.39-1.99-1.23-.74-.66-1.24-1.47-1.38-1.72-.15-.25-.02-.38.1-.51.11-.11.25-.29.37-.44.13-.15.17-.25.25-.41.09-.17.04-.31-.02-.44-.06-.12-.56-1.35-.77-1.85-.2-.48-.4-.42-.56-.43h-.47c-.16 0-.43.06-.65.31-.23.25-.86.84-.86 2.05s.88 2.38 1 2.54c.13.17 1.74 2.65 4.2 3.72.59.25 1.05.4 1.4.52.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.06-.11-.23-.17-.48-.29Z"/>
		</svg>
		Seguir en WhatsApp
	</a>
</aside>

<style>
	.canal {
		margin-top: 3.5rem;
		padding: 1.6rem 1.8rem;
		background: var(--verde);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.canal-titulo {
		font-family: 'Newsreader', serif;
		font-weight: 500;
		font-size: 1.35rem;
		line-height: 1.25;
		color: var(--papel);
		margin: 0 0 0.35rem;
	}

	.canal-bajada {
		font-size: 0.92rem;
		line-height: 1.5;
		color: rgba(244, 239, 227, 0.72);
		margin: 0;
	}

	.canal-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
		font-family: 'Work Sans', sans-serif;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--verde);
		background: var(--dorado-claro, #D4A24C);
		border-radius: 999px;
		padding: 0.65rem 1.3rem;
		transition: transform 0.15s ease, background 0.15s ease;
	}

	.canal-btn svg { width: 20px; height: 20px; }

	.canal-btn:hover {
		background: var(--papel);
		transform: translateY(-1px);
	}

	.canal-btn:focus-visible {
		outline: 2px solid var(--papel);
		outline-offset: 3px;
	}

	@media (max-width: 560px) {
		.canal {
			flex-direction: column;
			align-items: flex-start;
			gap: 1.2rem;
		}
		.canal-btn { align-self: stretch; justify-content: center; }
	}

	@media (prefers-reduced-motion: reduce) {
		.canal-btn { transition: none; }
	}
</style>
